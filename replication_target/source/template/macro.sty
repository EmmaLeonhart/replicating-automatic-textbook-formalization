% ... brackets
\def\bangle#1{\left\langle #1 \right\rangle}
\def\bbracket#1{\left\llbracket #1 \right\rrbracket}
\let\brace\relax
\def\brace#1{\left\{ #1 \right\}}
\def\bracket#1{\left[ #1 \right]}
\def\floor#1{\left\lfloor #1 \right\rfloor}
\def\ceil#1{\left\lceil #1 \right\rceil}
\def\paren#1{\left( #1 \right)}
\def\midvert{\,\middle\vert\,\mathopen{}}
\def\midvvert{\,\middle\vert\vert\,\mathopen{}}

% ... brackets type operations
\def\abs#1{\left| #1 \right|}
\def\module#1{\left| #1 \right|}
\def\norm#1{\left\| #1 \right\|}
\def\scap#1#2{\left\langle #1, #2 \right\rangle}
\def\bscap#1#2{\left\langle #1 \middle\vert #2 \right\rangle}

% ... brackets with delimiter
\providecommand{\midvertd}{\,\vert\,\mathopen{}}
\providecommand{\midvvertd}{\,\|\,\mathopen{}}
\DeclarePairedDelimiter\bangled{\langle}{\rangle}
\DeclarePairedDelimiter\bbracketd{\llbracket}{\rrbracket}
\let\braced\relax
\DeclarePairedDelimiterX\braced[1]{\{}{\}}{#1}
\DeclarePairedDelimiterX\bracketd[1]{[}{]}{#1}
\DeclarePairedDelimiter\ceild{\lceil}{\rceil}
\DeclarePairedDelimiter\floord{\lfloor}{\rfloor}
\DeclarePairedDelimiter\parend{(}{)}
\DeclarePairedDelimiter\absd{|}{|}
\DeclarePairedDelimiter\moduled{|}{|}
\DeclarePairedDelimiter\normd{\|}{\|}
\DeclarePairedDelimiterX\scapd[2]{\langle}{\rangle}{#1, #2}
\DeclarePairedDelimiterX\bscapd[2]{\langle}{\rangle}{#1\midvert #2}

% ... abbreviation
\def\Sfrak{\mathfrak{S}}
